# ─────────────────────────────────────────────────────────────────
# CarbonTrack — Environment Variables Example
# Copy this file to .env and fill in all values before running.
# ─────────────────────────────────────────────────────────────────

# ─── Application ─────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── Database ────────────────────────────────────────────────────
POSTGRES_DB=carbontrack
POSTGRES_USER=carbontrack
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# Prisma Database URL (auto-constructed in docker-compose)
DATABASE_URL=postgresql://carbontrack:CHANGE_ME_strong_password_here@localhost:5432/carbontrack?schema=public

# ─── JWT Authentication ───────────────────────────────────────────
# IMPORTANT: Change these to long random strings (min 32 chars)
# You can generate them with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_at_least_32_characters_long_access_secret
JWT_REFRESH_SECRET=CHANGE_ME_at_least_32_characters_long_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Security ────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── CORS ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost,http://localhost:5173

# ─── Frontend ────────────────────────────────────────────────────
VITE_API_URL=/api
