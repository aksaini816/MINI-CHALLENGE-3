// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["omitApi"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
  FAILED
}

enum ChallengeCategory {
  TRANSPORT
  ENERGY
  FOOD
  WASTE
  LIFESTYLE
}

enum ChallengeStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum ArticleCategory {
  CLIMATE_CHANGE
  CARBON_FOOTPRINT
  SUSTAINABLE_LIVING
  RENEWABLE_ENERGY
  FOOD_AND_DIET
  TRANSPORTATION
}

// ─────────────────────────────────────────────────────────────────
// User
// ─────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(USER)
  avatar       String?
  bio          String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens   RefreshToken[]
  carbonEntries   CarbonEntry[]
  goals           Goal[]
  userChallenges  UserChallenge[]
  badges          Badge[]
  notifications   Notification[]

  @@index([email])
  @@index([role])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────────
// Auth
// ─────────────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────────
// Carbon Entries
// ─────────────────────────────────────────────────────────────────

model CarbonEntry {
  id     String   @id @default(uuid())
  userId String
  date   DateTime @default(now())

  // Transportation (kg CO2 per month)
  carKm          Float @default(0)
  bikeKm         Float @default(0)
  publicTransportKm Float @default(0)
  flightKmPerYear   Float @default(0)

  // Home Energy (kg CO2 per month)
  electricityKwh   Float @default(0)
  naturalGasM3     Float @default(0)
  lpgKg            Float @default(0)

  // Food (kg CO2 per month)
  // dietType: VEGAN=0, VEGETARIAN=1, MIXED=2, HIGH_MEAT=3
  dietType String @default("MIXED")

  // Waste (kg CO2 per month)
  recyclingPercent Float @default(50)
  plasticKg        Float @default(0)
  generalWasteKg   Float @default(0)

  // Calculated totals (kg CO2)
  transportEmissions Float @default(0)
  energyEmissions    Float @default(0)
  foodEmissions      Float @default(0)
  wasteEmissions     Float @default(0)
  totalMonthly       Float @default(0)
  totalYearly        Float @default(0)
  sustainabilityScore Int  @default(0)

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
  @@map("carbon_entries")
}

// ─────────────────────────────────────────────────────────────────
// Goals
// ─────────────────────────────────────────────────────────────────

model Goal {
  id               String     @id @default(uuid())
  userId           String
  title            String
  description      String?
  targetReduction  Float      // percentage or kg CO2
  currentValue     Float      @default(0)
  baselineValue    Float      @default(0)
  unit             String     @default("kg CO2")
  deadline         DateTime
  status           GoalStatus @default(ACTIVE)
  category         String     @default("GENERAL")
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@map("goals")
}

// ─────────────────────────────────────────────────────────────────
// Challenges
// ─────────────────────────────────────────────────────────────────

model Challenge {
  id           String            @id @default(uuid())
  title        String
  description  String
  category     ChallengeCategory
  points       Int               @default(10)
  badge        String?
  duration     Int               @default(7) // days
  tips         String[]
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  userChallenges UserChallenge[]

  @@index([category])
  @@index([isActive])
  @@map("challenges")
}

model UserChallenge {
  id          String          @id @default(uuid())
  userId      String
  challengeId String
  status      ChallengeStatus @default(NOT_STARTED)
  startedAt   DateTime?
  completedAt DateTime?
  points      Int             @default(0)
  progress    Float           @default(0) // 0-100%
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@index([userId])
  @@index([challengeId])
  @@map("user_challenges")
}

// ─────────────────────────────────────────────────────────────────
// Badges
// ─────────────────────────────────────────────────────────────────

model Badge {
  id       String   @id @default(uuid())
  userId   String
  type     String
  title    String
  description String
  icon     String
  earnedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("badges")
}

// ─────────────────────────────────────────────────────────────────
// Articles / Knowledge Hub
// ─────────────────────────────────────────────────────────────────

model Article {
  id          String          @id @default(uuid())
  title       String
  slug        String          @unique
  excerpt     String
  content     String
  category    ArticleCategory
  tags        String[]
  author      String
  readTime    Int             @default(5) // minutes
  published   Boolean         @default(false)
  publishedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([category])
  @@index([published])
  @@index([slug])
  @@map("articles")
}

// ─────────────────────────────────────────────────────────────────
// Notifications
// ─────────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@map("notifications")
}
